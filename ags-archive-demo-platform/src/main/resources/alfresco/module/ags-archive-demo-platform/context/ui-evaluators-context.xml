<?xml version='1.0' encoding='UTF-8'?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
          http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <!--
        Registers the "archive" action with JSONConversionComponent so it appears in
        rmNode.actions for records and record folders.  The Share-side ActionEvaluator
        (evaluator.rm.action.archive) checks for this name in rmNode.actions.

        NotArchivedEvaluator suppresses the action for nodes that already carry the
        archive:archiveStatus aspect, preventing the action from appearing in the UI
        once archiving has completed.
    -->
    <bean id="jsonConversionComponent.archiveAction"
          parent="jsonConversionComponent.baseAction"
          class="org.hyland.archive.evaluator.NotArchivedEvaluator">
        <property name="name" value="archive"/>
        <property name="kinds">
            <set>
                <value>RECORD</value>
                <value>RECORD_FOLDER</value>
            </set>
        </property>
    </bean>

</beans>
